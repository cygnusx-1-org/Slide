    <style parent="Theme.MaterialComponents.Light.NoActionBar.Bridge" name="swipestylelight">
        <!-- Bridge enables Material's dark elevation overlay, which tints colorSurface
             with colorOnSurface (amber here) and turned dialogs olive. Disable it to
             keep the previous flat dialog/surface colors. -->
        <item name="elevationOverlayEnabled">false</item>
        <item name="colorAccent">@color/md_amber_A400</item>
        <!-- We keep colorSurface as #FF000000 here unless changed. -->
        <item name="colorSurface">#FF000000</item>
        <item name="colorOnSurface">?android:colorAccent</item>
    </style>

    <style parent="Theme.AppCompat.NoActionBar" name="swipeable">
        <item name="android:windowBackground">@null</item>
        <item name="android:windowIsTranslucent">true</item>
    </style>

    <style parent="Theme.AppCompat.NoActionBar" name="swipeableweb">
        <item name="android:windowBackground">@null</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="actionMenuTextColor">#DE000000</item>
        <item name="android:actionMenuTextColor">#DE000000</item>
        <item name="android:colorBackground">#dedede</item>
    </style>

    <style parent="Theme.MaterialComponents.NoActionBar.Bridge" name="swipestyle">
        <!-- See swipestylelight: avoid the Material dark elevation overlay tinting surfaces. -->
        <item name="elevationOverlayEnabled">false</item>
        <item name="colorAccent">@color/md_amber_A400</item>
        <item name="colorSurface">#FF000000</item>
        <item name="colorOnSurface">?android:colorAccent</item>
        <item name="android:windowActivityTransitions">true</item>
    </style>

    <!-- Full Material theme overlay for MaterialTimePicker. The app's base themes
         are MaterialComponents *.Bridge, which keep AppCompat widget styling and
         therefore do not define materialTimePickerTheme / the chip & clock styles
         the picker needs. Pass this explicitly via the picker builder's setTheme(). -->
    <style name="ThemeOverlay.App.TimePicker" parent="ThemeOverlay.MaterialComponents.TimePicker"/>

