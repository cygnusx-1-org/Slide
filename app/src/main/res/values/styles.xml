<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- 2dp rounded corners for ShapeableImageView (replaces makeramen riv_corner_radius) -->
    <style name="ShapeAppearanceOverlay.Slide.Corner2dp" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">2dp</item>
    </style>

    <!-- Material BottomSheetDialog theme for the cocosw-bottomsheet replacement (util/BottomSheet).
         Content supplies its own card_background, so the modal surface is transparent and the
         elevation overlay is disabled to avoid the tinted "olive" surface. -->
    <style name="Slide.BottomSheetDialog" parent="Theme.MaterialComponents.DayNight.BottomSheetDialog">
        <item name="elevationOverlayEnabled">false</item>
        <item name="bottomSheetStyle">@style/Slide.BottomSheetModal</item>
    </style>

    <style name="Slide.BottomSheetModal" parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="backgroundTint">@android:color/transparent</item>
    </style>

    <!-- From SwipeBackLayout -->
    <style name="SwipeBackLayout">
        <item name="edge_size">50dip</item>
        <item name="shadow_left">@drawable/shadow_left</item>
        <item name="shadow_right">@drawable/shadow_right</item>
        <item name="shadow_bottom">@drawable/shadow_bottom</item>
    </style>

    <style name="ActionBarCompat">
        <item name="android:textColorPrimary">@android:color/white</item>
        <item name="android:textColorSecondary">@android:color/white</item>
    </style>

    <style name="FontStyle"></style>

    <style name="FontStyle.HugeComment">
